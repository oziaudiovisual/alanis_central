<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Licença — Alanis</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <img src="/logo.webp" alt="Alanis" class="login-logo">
                <h1>Recuperar Licença</h1>
                <p>Informe seu email e CPF para recuperar sua chave</p>
            </div>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="15" y1="9" x2="9" y2="15" />
                        <line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    <%= error %>
                </div>
                <% } %>

                    <% if (typeof licenses !=='undefined' && licenses) { %>
                        <% if (licenses.length===0) { %>
                            <div class="alert alert-error">
                                Nenhuma licença encontrada para esse email e CPF. Verifique seus dados.
                            </div>
                            <% } else { %>
                                <div class="recovery-results">
                                    <% licenses.forEach(function(l) { %>
                                        <div class="recovery-card">
                                            <div class="recovery-plan">
                                                <%= l.plan %>
                                            </div>
                                            <div class="recovery-key">
                                                <label>Sua chave de licença:</label>
                                                <div class="recovery-key-box">
                                                    <code id="key-<%= l.id %>"><%= l.license_key %></code>
                                                    <button
                                                        onclick="navigator.clipboard.writeText('<%= l.license_key %>');this.textContent='✓ Copiada';setTimeout(()=>this.textContent='Copiar',2000)"
                                                        class="btn btn-sm btn-primary">Copiar</button>
                                                </div>
                                            </div>
                                            <div class="recovery-status">
                                                <% if (l.status==='active' ) { %>
                                                    <span class="badge badge-license-active">✅ Licença Ativa</span>
                                                    <% if (l.expires_at) { %>
                                                        <p class="recovery-expires">Expira em: <%= new
                                                                Date(l.expires_at).toLocaleString('pt-BR', {
                                                                timeZone: 'America/Sao_Paulo' }) %>
                                                        </p>
                                                        <% } %>
                                                            <% } else if (l.status==='cancelled' ) { %>
                                                                <span class="badge badge-license-cancelled">❌ Licença
                                                                    Cancelada</span>
                                                                <% if (l.cancel_reason==='refund' ) { %>
                                                                    <p class="recovery-reason">Motivo: Reembolso
                                                                        solicitado</p>
                                                                    <% } else if (l.cancel_reason==='chargeback' ) { %>
                                                                        <p class="recovery-reason">Motivo: Chargeback
                                                                            registrado</p>
                                                                        <% } %>
                                                                            <% } else if (l.status==='expired' ) { %>
                                                                                <span
                                                                                    class="badge badge-license-expired">⏰
                                                                                    Licença Expirada</span>
                                                                                <% } else if (l.status==='suspended' ) {
                                                                                    %>
                                                                                    <span
                                                                                        class="badge badge-license-suspended">⚠️
                                                                                        Licença Suspensa</span>
                                                                                    <% } %>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } %>
                                    <% } %>

                                        <form method="POST" action="/license/recover" class="login-form">
                                            <div class="form-group">
                                                <label for="email">Email de compra</label>
                                                <input type="email" id="email" name="email" class="form-input"
                                                    placeholder="seu@email.com" required
                                                    value="<%= typeof email !== 'undefined' ? email : '' %>">
                                            </div>
                                            <div class="form-group">
                                                <label for="doc">CPF</label>
                                                <input type="text" id="doc" name="doc" class="form-input"
                                                    placeholder="000.000.000-00" required maxlength="14"
                                                    value="<%= typeof doc !== 'undefined' ? doc : '' %>">
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-full">Recuperar
                                                Licença</button>
                                        </form>


        </div>
    </div>

    <script>
        document.getElementById('doc').addEventListener('input', function (e) {
            let v = e.target.value.replace(/\D/g, '');
            if (v.length > 11) v = v.substring(0, 11);
            if (v.length > 9) v = v.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
            else if (v.length > 6) v = v.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
            else if (v.length > 3) v = v.replace(/(\d{3})(\d{1,3})/, '$1.$2');
            e.target.value = v;
        });
    </script>
</body>

</html>