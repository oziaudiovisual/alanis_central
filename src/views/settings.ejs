<%- include('partials/header') %>

    <div class="page-header">
        <h1>Configurações</h1>
        <p class="subtitle">Webhook e segurança</p>
    </div>

    <% if (success) { %>
        <div class="alert alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
            <%= success %>
        </div>
        <% } %>

            <% if (error) { %>
                <div class="alert alert-error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="15" y1="9" x2="9" y2="15" />
                        <line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    <%= error %>
                </div>
                <% } %>

                    <!-- Webhook Config -->
                    <div class="card settings-card">
                        <div class="card-header">
                            <h2>🔗 Webhook da Cakto</h2>
                        </div>
                        <div class="card-body">
                            <div class="settings-info">
                                <p>Configure a URL abaixo na Cakto como destino do webhook:</p>
                                <div class="webhook-url-box">
                                    <code id="webhookUrl"></code>
                                    <button class="btn btn-sm btn-ghost" onclick="copyWebhookUrl()" title="Copiar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <form method="POST" action="/settings/webhook-secret" class="settings-form">
                                <div class="form-group">
                                    <label for="webhook_secret">Chave Secreta do Webhook</label>
                                    <p class="form-help">Essa chave deve ser a mesma configurada na Cakto para validar
                                        os webhooks recebidos.</p>
                                    <input type="text" id="webhook_secret" name="webhook_secret"
                                        value="<%= admin.webhook_secret || '' %>"
                                        placeholder="Sua chave secreta da Cakto" class="form-input">
                                </div>
                                <button type="submit" class="btn btn-primary">Salvar Secret</button>
                            </form>
                        </div>
                    </div>

                    <!-- Change Password -->
                    <div class="card settings-card">
                        <div class="card-header">
                            <h2>🔒 Alterar Senha</h2>
                        </div>
                        <div class="card-body">
                            <form method="POST" action="/settings/password" class="settings-form">
                                <div class="form-group">
                                    <label for="current_password">Senha Atual</label>
                                    <input type="password" id="current_password" name="current_password" required
                                        class="form-input">
                                </div>
                                <div class="form-group">
                                    <label for="new_password">Nova Senha</label>
                                    <input type="password" id="new_password" name="new_password" required minlength="6"
                                        class="form-input">
                                </div>
                                <div class="form-group">
                                    <label for="confirm_password">Confirmar Nova Senha</label>
                                    <input type="password" id="confirm_password" name="confirm_password" required
                                        minlength="6" class="form-input">
                                </div>
                                <button type="submit" class="btn btn-primary">Atualizar Senha</button>
                            </form>
                        </div>
                    </div>

                    <script>
                        document.getElementById('webhookUrl').textContent = window.location.origin + '/webhook/cakto';
                        function copyWebhookUrl() {
                            navigator.clipboard.writeText(window.location.origin + '/webhook/cakto');
                            alert('URL copiada!');
                        }
                    </script>

                    <%- include('partials/footer') %>