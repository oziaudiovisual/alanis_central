{
    "services": [
        {
            "type": "app",
            "data": {
                "serviceName": "central",
                "source": {
                    "type": "github",
                    "owner": "oziaudiovisual",
                    "repo": "alanis_central",
                    "ref": "main",
                    "path": "/",
                    "autoDeploy": false
                },
                "build": {
                    "type": "dockerfile",
                    "file": "Dockerfile"
                },
                "env": "DATABASE_URL=postgresql://postgres:central_db_2024@$(PROJECT_NAME)_central-db:5432/$(PROJECT_NAME)\nSESSION_SECRET=TROQUE_POR_CHAVE_SEGURA_64_CHARS\nNODE_ENV=production\nPORT=3000\nADMIN_EMAIL=admin@alanis.com\nADMIN_PASSWORD=admin123",
                "deploy": {
                    "replicas": 1,
                    "command": null,
                    "zeroDowntime": true
                },
                "domains": [
                    {
                        "host": "$(EASYPANEL_DOMAIN)",
                        "https": true,
                        "port": 3000,
                        "path": "/"
                    }
                ],
                "mounts": [],
                "ports": []
            }
        },
        {
            "type": "postgres",
            "data": {
                "serviceName": "central-db",
                "image": "postgres:16-alpine",
                "password": "central_db_2024"
            }
        }
    ]
}